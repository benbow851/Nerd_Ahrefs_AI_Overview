# Copy to .env.local and fill in (never commit .env.local).

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ahrefs (v3 API token) — server-only, used for Pull Snapshot
AHREFS_API_KEY=

# Optional: IANA tz for default “yesterday” pull date (client + server). Default Asia/Bangkok.
# NEXT_PUBLIC_SNAPSHOT_CALENDAR_TIMEZONE=Asia/Bangkok

# Public site URL (local or Vercel), used for auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
